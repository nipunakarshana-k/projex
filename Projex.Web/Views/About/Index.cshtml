@model List<TeamMember>
@{
    ViewData["Title"] = "About Us";
}

<!-- ════ PAGE HERO ════ -->
<section class="page-hero-mm"
         style="background-image:url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1920&q=85&fit=crop&auto=format');">
  <div class="page-hero-mm-overlay"></div>
  <div class="container page-hero-mm-inner">
    <ul class="bc-nav">
      <li><a href="/">Home</a></li>
      <li class="bc-sep">/</li>
      <li class="active">About Us</li>
    </ul>
    <h1 class="page-hero-mm-title">About Project Excellence</h1>
    <p class="page-hero-mm-sub">A trusted partner who stands firmly on your side — commercially, strategically, and technically.</p>
  </div>
</section>

<!-- ════ COMPANY STORY ════ -->
<section class="section-pad" style="background:#fff;">
  <div class="container">
    <div class="row align-items-center g-5">

      <div class="col-lg-6 fade-up">
        <span class="section-label">Our Story</span>
        <h2 class="section-title">Founded on a Core Belief</h2>
        <div class="divider-accent"></div>
        <p style="color:var(--text-body);line-height:1.85;font-size:1.02rem;margin-bottom:20px;">
          Project Excellence Pvt Ltd was founded on a core belief: <strong>clients deserve a trusted advisor who protects their interests</strong> — commercially, strategically, and technically — from the very beginning of a project to its final completion.
        </p>
        <p style="color:var(--text-muted);line-height:1.85;margin-bottom:20px;">
          In a construction market where budgets shift, risks escalate, and decisions must be made quickly and confidently, we recognised a major gap: <em>the need for independent, high-calibre advisory supported by disciplined project management and robust cost consultancy.</em>
        </p>
        <p style="color:var(--text-muted);line-height:1.85;margin-bottom:36px;">
          With professional experience across Sri Lanka, Singapore, and Australia, our team brings global insight into how successful projects are planned, evaluated, governed, and delivered.
        </p>
        <a href="/Contact" class="btn-pb"><i class="bi bi-arrow-right-circle-fill"></i> Work With Us</a>
      </div>

      <div class="col-lg-6 fade-in">
        <!-- Promise block — Modern Minimal -->
        <div style="background:#111111;border-radius:16px;padding:48px 44px;border:1px solid #222;">

          <!-- Label -->
          <div style="display:inline-flex;align-items:center;gap:8px;font-family:'Inter',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:#2389CA;margin-bottom:28px;">
            <span style="width:20px;height:1px;background:#2389CA;display:inline-block;"></span>
            Our Promise
          </div>

          <!-- Quote -->
          <p style="font-family:'Inter',sans-serif;font-size:1.15rem;font-weight:600;line-height:1.65;color:#fff;margin:0 0 40px;letter-spacing:-.01em;">
            "Clear advisory. Strong cost intelligence. Reliable project execution. A partner who stands firmly on your side."
          </p>

          <!-- Divider -->
          <div style="height:1px;background:#222;margin-bottom:36px;"></div>

          <!-- Stats -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;">
            <div style="text-align:center;padding:0 16px;">
              <div style="font-family:'Inter',sans-serif;font-size:2.4rem;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em;">17<span style="font-size:1.4rem;color:#2389CA;">+</span></div>
              <div style="font-size:.72rem;color:rgba(255,255,255,.4);margin-top:8px;letter-spacing:.1em;text-transform:uppercase;">Years Experience</div>
            </div>
            <div style="text-align:center;padding:0 16px;border-left:1px solid #222;border-right:1px solid #222;">
              <div style="font-family:'Inter',sans-serif;font-size:2.4rem;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em;">3</div>
              <div style="font-size:.72rem;color:rgba(255,255,255,.4);margin-top:8px;letter-spacing:.1em;text-transform:uppercase;">Countries</div>
            </div>
            <div style="text-align:center;padding:0 16px;">
              <div style="font-family:'Inter',sans-serif;font-size:2.4rem;font-weight:800;color:#fff;line-height:1;letter-spacing:-.04em;">100<span style="font-size:1.4rem;color:#2389CA;">%</span></div>
              <div style="font-size:.72rem;color:rgba(255,255,255,.4);margin-top:8px;letter-spacing:.1em;text-transform:uppercase;">Independent</div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<!-- ════ IMAGE BREAK ════ -->
<div style="height:420px;overflow:hidden;position:relative;">
  <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1920&q=80&fit=crop&auto=format"
       alt="Modern building exterior" loading="lazy"
       style="width:100%;height:100%;object-fit:cover;object-position:center 60%;" />
  <div style="position:absolute;inset:0;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center;">
    <p style="font-family:var(--font-h);font-size:clamp(1.4rem,3vw,2.4rem);font-weight:800;color:#fff;text-align:center;max-width:720px;line-height:1.3;letter-spacing:-.03em;padding:0 24px;">
      "We bring global standards of governance and advisory thinking into every project we support."
    </p>
  </div>
</div>

<!-- ════ VISION & MISSION ════ -->
<section class="section-pad" style="background:var(--off-white,#F7F6F3);">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">Our Direction</span>
      <h2 class="section-title">Vision &amp; Mission</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4">
      <div class="col-lg-6 fade-up">
        <div style="background:#fff;border:1px solid var(--border,#E8E8E4);border-top:3px solid var(--accent);border-radius:14px;padding:44px 40px;height:100%;">
          <div style="font-family:var(--font-h);font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;">Vision</div>
          <h3 style="font-size:1.35rem;font-weight:800;color:var(--primary);margin-bottom:16px;letter-spacing:-.02em;">Setting a New Benchmark</h3>
          <p style="color:var(--text-muted);line-height:1.85;font-size:.96rem;">
            To set a new benchmark in client-side project advisory — empowering owners and investors with clarity, confidence, and commercially intelligent guidance that transforms how projects are planned, governed, and delivered.
          </p>
        </div>
      </div>
      <div class="col-lg-6 fade-up">
        <div style="background:var(--charcoal,#111);border-radius:14px;padding:44px 40px;height:100%;">
          <div style="font-family:var(--font-h);font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:14px;">Mission</div>
          <h3 style="font-size:1.35rem;font-weight:800;color:#fff;margin-bottom:16px;letter-spacing:-.02em;">Delivering Purposeful Outcomes</h3>
          <p style="color:rgba(255,255,255,.6);line-height:1.85;font-size:.96rem;">
            We strive to deliver informed decisions, proactive risk control, and transparent communication — ensuring every project moves forward with purpose, precision, and measurable value.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ THREE PRINCIPLES ════ -->
<section class="section-pad" style="background:#fff;">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">Our Foundation</span>
      <h2 class="section-title">The Three Principles That Define Us</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4 stagger-parent">
      <div class="col-lg-4 fade-up">
        <div class="value-card h-100">
          <div class="value-label">Principle 01</div>
          <div class="value-title">Excellence</div>
          <div class="value-desc">In advisory quality, communication, and decision support. Every engagement is approached with the highest standards of technical insight and client service — no exceptions.</div>
        </div>
      </div>
      <div class="col-lg-4 fade-up">
        <div class="value-card h-100">
          <div class="value-label">Principle 02</div>
          <div class="value-title">Execution</div>
          <div class="value-desc">Delivering consistent, structured, and proactive management across every stage. We follow through on every commitment — keeping your project on track and your team aligned.</div>
        </div>
      </div>
      <div class="col-lg-4 fade-up">
        <div class="value-card h-100">
          <div class="value-label">Principle 03</div>
          <div class="value-title">Expertise</div>
          <div class="value-desc">Applying technical, commercial, and strategic insight to add real value. Our team's international exposure and multi-disciplinary knowledge sets us apart from the competition.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SERVICE IDENTITY ════ -->
<section class="section-pad" style="background:var(--off-white,#F7F6F3);">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-5 fade-up">
        <span class="section-label">Service Identity</span>
        <h2 class="section-title">Three Disciplines. One Trusted Partner.</h2>
        <div class="divider-accent"></div>
        <p style="color:var(--text-muted);line-height:1.85;margin-bottom:32px;">
          Our service identity is intentionally balanced — combining advisory, management, and cost disciplines into a single, integrated offering that gives clients complete project confidence.
        </p>
        <div class="split-image-block" style="aspect-ratio:4/3;border-radius:14px;">
          <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=800&q=80&fit=crop&auto=format"
               alt="Architectural blueprints and plans" loading="lazy" />
        </div>
      </div>
      <div class="col-lg-7 fade-up">
        <div class="service-feature-item">
          <div class="feature-check"><i class="bi bi-shield-check"></i></div>
          <div>
            <div class="feature-text-title">Client Advisory</div>
            <div class="feature-text-desc">Strategic guidance, risk insight, commercial positioning, decision support, and client representation throughout the project lifecycle.</div>
          </div>
        </div>
        <div class="service-feature-item">
          <div class="feature-check"><i class="bi bi-diagram-3"></i></div>
          <div>
            <div class="feature-text-title">Project Management</div>
            <div class="feature-text-desc">Coordinated execution, progress control, stakeholder alignment, and structured delivery that keeps every project moving forward with precision.</div>
          </div>
        </div>
        <div class="service-feature-item">
          <div class="feature-check"><i class="bi bi-pencil-square"></i></div>
          <div>
            <div class="feature-text-title">Design Management</div>
            <div class="feature-text-desc">Client-side design leadership ensuring every discipline aligns with objectives — technically sound and commercially viable.</div>
          </div>
        </div>
        <div class="service-feature-item">
          <div class="feature-check"><i class="bi bi-calculator"></i></div>
          <div>
            <div class="feature-text-title">Cost Consultancy</div>
            <div class="feature-text-desc">Cost planning, value engineering, estimates, commercial assessments, and claim evaluation to protect your financial investment at every stage.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ TEAM ════ -->
@if (Model.Any())
{
<section class="section-pad" style="background:#fff;">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">Our Team</span>
      <h2 class="section-title">Leadership &amp; Expertise</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4 justify-content-center stagger-parent">
      @foreach (var member in Model)
      {
      <div class="col-lg-5 col-md-8 fade-up">
        <div style="background:#fff;border:1px solid var(--border,#E8E8E4);border-radius:14px;padding:36px;height:100%;transition:all .3s ease;" onmouseover="this.style.boxShadow='0 8px 32px rgba(0,0,0,.08)';this.style.transform='translateY(-3px)'" onmouseout="this.style.boxShadow='';this.style.transform=''">
          <div class="d-flex align-items-center gap-4 mb-4">
            <div style="width:68px;height:68px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--accent));display:flex;align-items:center;justify-content:center;font-family:var(--font-h);font-size:1.3rem;font-weight:800;color:#fff;flex-shrink:0;">
              @(member.Name.Split(' ').Length > 1 ? member.Name.Split(' ')[0][0].ToString() + member.Name.Split(' ')[^1][0].ToString() : member.Name[0].ToString())
            </div>
            <div>
              <div style="font-family:var(--font-h);font-size:1.05rem;font-weight:700;color:var(--primary);margin-bottom:3px;">@member.Name</div>
              <div style="font-size:.85rem;color:var(--accent);font-weight:600;">@member.Title</div>
            </div>
          </div>
          @if (!string.IsNullOrEmpty(member.Credentials))
          {
          <div style="font-size:.82rem;color:var(--text-muted);font-style:italic;border-top:1px solid var(--border,#E8E8E4);padding-top:14px;margin-bottom:14px;">
            @member.Credentials
          </div>
          }
          @if (!string.IsNullOrEmpty(member.Bio))
          {
          <p style="font-size:.88rem;color:var(--text-muted);line-height:1.75;margin:0;">@member.Bio.Split('\n')[0]</p>
          }
        </div>
      </div>
      }
    </div>
  </div>
</section>
}

<!-- ════ CTA ════ -->
<section class="cta-section section-pad">
  <div class="container">
    <div class="cta-section-inner fade-up">
      <span class="section-label" style="color:rgba(255,255,255,.4);">Work With Us</span>
      <h2 class="cta-title">Ready to Work With a Trusted Project Partner?</h2>
      <p class="cta-subtitle">Let us bring clarity, structure, and commercially intelligent advisory to your next project.</p>
      <div class="d-flex gap-3 flex-wrap justify-content-center">
        <a href="/Contact" class="btn-pb"><i class="bi bi-envelope-fill"></i> Get In Touch</a>
        <a href="/Services" class="btn-ob"><i class="bi bi-grid-3x3-gap-fill"></i> Our Services</a>
      </div>
    </div>
  </div>
</section>
