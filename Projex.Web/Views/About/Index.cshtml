@model List<TeamMember>
@{
    ViewData["Title"] = "About Us";
}

<!-- Page Hero -->
<section class="page-hero">
  <div class="container position-relative" style="z-index:2;">
    <ul class="bc-nav">
      <li><a href="/">Home</a></li>
      <li class="bc-sep">/</li>
      <li class="active">About Us</li>
    </ul>
    <h1 class="page-hero-title">About Project Excellence</h1>
    <p class="page-hero-sub">A trusted partner who stands firmly on your side — commercially, strategically, and technically.</p>
  </div>
</section>

<!-- Company Story -->
<section class="section-pad">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6 fade-up">
        <span class="section-label">Our Story</span>
        <h2 class="section-title">Founded on a Core Belief</h2>
        <div class="divider-accent"></div>
        <p class="mb-4" style="color:var(--text-body);line-height:1.85;font-size:1.02rem;">
          Project Excellence Pvt Ltd was founded on a core belief: <strong>clients deserve a trusted advisor who protects their interests</strong> — commercially, strategically, and technically — from the very beginning of a project to its final completion.
        </p>
        <p class="mb-4" style="color:var(--text-muted);line-height:1.85;">
          In a construction market where budgets shift, risks escalate, and decisions must be made quickly and confidently, we recognised a major gap: <em>the need for independent, high-calibre advisory supported by disciplined project management and robust cost consultancy.</em>
        </p>
        <p style="color:var(--text-muted);line-height:1.85;">
          With professional experience across Sri Lanka, Singapore, and Australia, our team brings global insight into how successful projects are planned, evaluated, governed, and delivered. We blend strategic advisory with cost intelligence and structured execution — giving clients the clarity they need to make the right decisions at the right time.
        </p>
      </div>
      <div class="col-lg-6 fade-in">
        <div style="background:var(--gradient-hero);border-radius:24px;padding:48px 40px;color:var(--white);">
          <div class="mb-4" style="font-family:var(--font-h);font-size:.72rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent-light);">Our Promise</div>
          <blockquote style="font-size:1.3rem;font-weight:700;font-family:var(--font-h);line-height:1.5;margin-bottom:28px;">
            "Clear advisory. Strong cost intelligence. Reliable project execution. A project partner who stands firmly on your side."
          </blockquote>
          <div class="d-flex gap-3 flex-wrap">
            <div style="text-align:center;">
              <div style="font-family:var(--font-h);font-size:2rem;font-weight:800;color:var(--white);">17+</div>
              <div style="font-size:.78rem;color:rgba(255,255,255,.65);">Years Experience</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,.15);"></div>
            <div style="text-align:center;">
              <div style="font-family:var(--font-h);font-size:2rem;font-weight:800;color:var(--white);">3</div>
              <div style="font-size:.78rem;color:rgba(255,255,255,.65);">Countries</div>
            </div>
            <div style="width:1px;background:rgba(255,255,255,.15);"></div>
            <div style="text-align:center;">
              <div style="font-family:var(--font-h);font-size:2rem;font-weight:800;color:var(--white);">100%</div>
              <div style="font-size:.78rem;color:rgba(255,255,255,.65);">Independent</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Vision & Mission -->
<section class="section-pad bg-grey-light">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">Our Direction</span>
      <h2 class="section-title">Vision &amp; Mission</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4">
      <div class="col-lg-6 fade-up">
        <div class="contact-card h-100" style="border-top:4px solid var(--accent);">
          <div style="font-family:var(--font-h);font-size:.7rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;">Vision</div>
          <h3 style="font-size:1.3rem;font-weight:700;color:var(--primary);margin-bottom:16px;">Setting a New Benchmark</h3>
          <p style="color:var(--text-muted);line-height:1.8;">
            To set a new benchmark in client-side project advisory — empowering owners and investors with clarity, confidence, and commercially intelligent guidance that transforms how projects are planned, governed, and delivered.
          </p>
        </div>
      </div>
      <div class="col-lg-6 fade-up">
        <div class="contact-card h-100" style="border-top:4px solid var(--primary);">
          <div style="font-family:var(--font-h);font-size:.7rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--primary);margin-bottom:12px;">Mission</div>
          <h3 style="font-size:1.3rem;font-weight:700;color:var(--primary);margin-bottom:16px;">Delivering Purposeful Outcomes</h3>
          <p style="color:var(--text-muted);line-height:1.8;">
            We strive to deliver informed decisions, proactive risk control, and transparent communication — ensuring every project moves forward with purpose, precision, and measurable value.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Principles -->
<section class="section-pad">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">Our Foundation</span>
      <h2 class="section-title">The Three Principles That Define Us</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4">
      <div class="col-lg-4 fade-up">
        <div class="value-card h-100">
          <div class="value-label">Principle 01</div>
          <div class="value-title">Excellence</div>
          <div class="value-desc">In advisory quality, communication, and decision support. Every engagement is approached with the highest standards of technical insight and client service — no exceptions.</div>
        </div>
      </div>
      <div class="col-lg-4 fade-up">
        <div class="value-card h-100">
          <div class="value-label">Principle 02</div>
          <div class="value-title">Execution</div>
          <div class="value-desc">Delivering consistent, structured, and proactive management across every stage. We follow through on every commitment — keeping your project on track and your team aligned.</div>
        </div>
      </div>
      <div class="col-lg-4 fade-up">
        <div class="value-card h-100">
          <div class="value-label">Principle 03</div>
          <div class="value-title">Expertise</div>
          <div class="value-desc">Applying technical, commercial, and strategic insight to add real value. Our team's international exposure and multi-disciplinary knowledge sets us apart from the competition.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Our Services Identity -->
<section class="section-pad bg-grey-light">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-5 fade-up">
        <span class="section-label">Service Identity</span>
        <h2 class="section-title">Three Disciplines. One Trusted Partner.</h2>
        <div class="divider-accent"></div>
        <p style="color:var(--text-muted);line-height:1.8;">
          Our service identity is intentionally balanced — combining advisory, management, and cost disciplines into a single, integrated offering that gives clients complete project confidence.
        </p>
      </div>
      <div class="col-lg-7">
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-shield-check"></i></div>
          <div>
            <div class="feature-text-title">Client Advisory</div>
            <div class="feature-text-desc">Strategic guidance, risk insight, commercial positioning, decision support, and client representation throughout the project lifecycle.</div>
          </div>
        </div>
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-diagram-3"></i></div>
          <div>
            <div class="feature-text-title">Project Management</div>
            <div class="feature-text-desc">Coordinated execution, progress control, stakeholder alignment, and structured delivery that keeps every project moving forward with precision.</div>
          </div>
        </div>
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-calculator"></i></div>
          <div>
            <div class="feature-text-title">Cost Consultancy</div>
            <div class="feature-text-desc">Cost planning, value engineering, estimates, commercial assessments, and claim evaluation to protect your financial investment at every stage.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Team -->
@if (Model.Any())
{
<section class="section-pad">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">Our Team</span>
      <h2 class="section-title">Leadership &amp; Expertise</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4 justify-content-center stagger-parent">
      @foreach (var member in Model)
      {
      <div class="col-lg-5 col-md-8">
        <div class="team-card fade-up text-start">
          <div class="d-flex align-items-center gap-4 mb-24" style="margin-bottom:20px;">
            <div class="team-avatar" style="width:72px;height:72px;font-size:1.3rem;flex-shrink:0;">
              @(member.Name.Split(' ').Length > 2 ? member.Name.Split(' ')[1][0].ToString() : member.Name[0].ToString())
            </div>
            <div>
              <div class="team-name text-start">@member.Name</div>
              <div class="team-role text-start">@member.Title</div>
            </div>
          </div>
          @if (!string.IsNullOrEmpty(member.Credentials))
          {
          <div class="team-creds text-start" style="border-top:1px solid var(--grey-mid);padding-top:14px;margin-bottom:16px;">
            @member.Credentials
          </div>
          }
          @if (!string.IsNullOrEmpty(member.Bio))
          {
          <p style="font-size:.88rem;color:var(--text-muted);line-height:1.75;">@member.Bio.Split('\n')[0]</p>
          }
        </div>
      </div>
      }
    </div>
  </div>
</section>
}

<!-- CTA -->
<section class="cta-section section-pad">
  <div class="container position-relative fade-up">
    <div class="row">
      <div class="col-lg-7">
        <span class="section-label" style="color:rgba(176,210,237,.8);">Work With Us</span>
        <h2 class="cta-title">Ready to Work With a Trusted Project Partner?</h2>
        <p class="cta-subtitle">Let us bring clarity, structure, and commercially intelligent advisory to your next project.</p>
        <div class="d-flex gap-3 flex-wrap">
          <a href="/Contact" class="btn-pb" style="background:rgba(255,255,255,.15);backdrop-filter:blur(10px);border:1.5px solid rgba(255,255,255,.4);box-shadow:none;">
            <i class="bi bi-envelope-fill"></i> Get In Touch
          </a>
          <a href="/Services" class="btn-ob">
            <i class="bi bi-grid-3x3-gap-fill"></i> Our Services
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
