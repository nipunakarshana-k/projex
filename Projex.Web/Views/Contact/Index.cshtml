@model ContactMessage
@{
    ViewData["Title"] = "Contact Us";
}

<section class="page-hero">
  <div class="container position-relative" style="z-index:2;">
    <ul class="bc-nav">
      <li><a href="/">Home</a></li>
      <li class="bc-sep">/</li>
      <li class="active">Contact Us</li>
    </ul>
    <h1 class="page-hero-title">Get In Touch</h1>
    <p class="page-hero-sub">Have a project in mind? We'd love to hear about it. Let's start a conversation about how we can help you achieve your project goals.</p>
  </div>
</section>

<section class="section-pad">
  <div class="container">
    @if (TempData["SuccessMessage"] != null)
    {
    <div class="alert-success-b mb-5 fade-up">
      <i class="bi bi-check-circle-fill" style="font-size:1.3rem;color:var(--accent);flex-shrink:0;"></i>
      <div>
        <strong style="display:block;margin-bottom:4px;">Message Sent Successfully!</strong>
        @TempData["SuccessMessage"]
      </div>
    </div>
    }

    <div class="row g-5">
      <!-- Form -->
      <div class="col-lg-7 fade-up">
        <div class="contact-card">
          <div class="mb-4">
            <span class="section-label">Send a Message</span>
            <h2 class="section-title" style="font-size:1.6rem;">Tell Us About Your Project</h2>
            <div class="divider-accent"></div>
          </div>

          <form asp-action="Index" asp-controller="Contact" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <div class="row g-3">
              <div class="col-md-6">
                <label asp-for="FullName" class="form-label-b"></label>
                <input asp-for="FullName" class="form-ctrl-b" placeholder="e.g. John Smith" required />
                <span asp-validation-for="FullName" class="form-error"></span>
              </div>
              <div class="col-md-6">
                <label asp-for="Email" class="form-label-b"></label>
                <input asp-for="Email" type="email" class="form-ctrl-b" placeholder="your@email.com" required />
                <span asp-validation-for="Email" class="form-error"></span>
              </div>
              <div class="col-md-6">
                <label asp-for="Phone" class="form-label-b"></label>
                <input asp-for="Phone" type="tel" class="form-ctrl-b" placeholder="+94 XX XXX XXXX" />
                <span asp-validation-for="Phone" class="form-error"></span>
              </div>
              <div class="col-md-6">
                <label asp-for="Company" class="form-label-b"></label>
                <input asp-for="Company" class="form-ctrl-b" placeholder="Your company name" />
              </div>
              <div class="col-md-6">
                <label asp-for="ProjectType" class="form-label-b">Project Type</label>
                <select asp-for="ProjectType" class="form-ctrl-b">
                  <option value="">— Select Project Type —</option>
                  <option>Residential Development</option>
                  <option>Commercial Building</option>
                  <option>Mixed-Use Development</option>
                  <option>Apartment Building</option>
                  <option>Institutional / Educational</option>
                  <option>Hospitality &amp; Leisure</option>
                  <option>Industrial Project</option>
                  <option>Investor-Driven Project</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="col-md-6">
                <label asp-for="Subject" class="form-label-b"></label>
                <input asp-for="Subject" class="form-ctrl-b" placeholder="Brief subject line" required />
                <span asp-validation-for="Subject" class="form-error"></span>
              </div>
              <div class="col-12">
                <label asp-for="Message" class="form-label-b"></label>
                <textarea asp-for="Message" class="form-ctrl-b" rows="5" placeholder="Tell us about your project, objectives, and how we can help..." required style="resize:vertical;"></textarea>
                <span asp-validation-for="Message" class="form-error"></span>
              </div>
              <div class="col-12 mt-2">
                <button type="submit" class="btn-pb">
                  <i class="bi bi-send-fill"></i> Send Message
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="col-lg-5 fade-in">
        <div class="mb-5">
          <span class="section-label">Contact Information</span>
          <h3 style="font-size:1.4rem;font-weight:700;color:var(--primary);margin-bottom:8px;">We'd Love to Hear From You</h3>
          <div class="divider-accent"></div>
          <p style="color:var(--text-muted);line-height:1.8;">Reach out to discuss your project requirements. We provide confidential, obligation-free initial consultations.</p>
        </div>

        <div class="contact-info-item">
          <div class="contact-info-icon"><i class="bi bi-geo-alt-fill"></i></div>
          <div>
            <div class="ci-label">Office Locations</div>
            <div class="ci-val">Sri Lanka &bull; Singapore &bull; Australia</div>
          </div>
        </div>

        <div class="contact-info-item">
          <div class="contact-info-icon"><i class="bi bi-envelope-fill"></i></div>
          <div>
            <div class="ci-label">Email Address</div>
            <div class="ci-val">info@projectexcellence.lk</div>
          </div>
        </div>

        <div class="contact-info-item">
          <div class="contact-info-icon"><i class="bi bi-telephone-fill"></i></div>
          <div>
            <div class="ci-label">Phone</div>
            <div class="ci-val">+94 XX XXX XXXX</div>
          </div>
        </div>

        <div class="contact-info-item">
          <div class="contact-info-icon"><i class="bi bi-clock-fill"></i></div>
          <div>
            <div class="ci-label">Business Hours</div>
            <div class="ci-val">Monday – Friday, 9:00 AM – 5:30 PM</div>
          </div>
        </div>

        <!-- What to expect -->
        <div style="background:var(--grey-light);border-radius:var(--radius-lg);padding:28px;margin-top:32px;">
          <div style="font-family:var(--font-h);font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;">What to Expect</div>
          <div class="service-feature-item" style="padding:10px 0;border-bottom:1px solid var(--grey-mid);">
            <div class="feature-check" style="width:24px;height:24px;font-size:.7rem;flex-shrink:0;"><i class="bi bi-check"></i></div>
            <div style="font-size:.88rem;color:var(--text-muted);">Response within 24 business hours</div>
          </div>
          <div class="service-feature-item" style="padding:10px 0;border-bottom:1px solid var(--grey-mid);">
            <div class="feature-check" style="width:24px;height:24px;font-size:.7rem;flex-shrink:0;"><i class="bi bi-check"></i></div>
            <div style="font-size:.88rem;color:var(--text-muted);">Confidential initial consultation</div>
          </div>
          <div class="service-feature-item" style="padding:10px 0;border-bottom:none;">
            <div class="feature-check" style="width:24px;height:24px;font-size:.7rem;flex-shrink:0;"><i class="bi bi-check"></i></div>
            <div style="font-size:.88rem;color:var(--text-muted);">No-obligation project discussion</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
