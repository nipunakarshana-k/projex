@model List<Projex.Web.Models.ContactMessage>
@{
    ViewData["Title"] = "Admin – Enquiries";
    Layout = "_Layout";
}

<section class="page-hero" style="padding:120px 0 50px;">
  <div class="container position-relative" style="z-index:2;">
    <h1 class="page-hero-title" style="font-size:2rem;">Contact Enquiries</h1>
    <p class="page-hero-sub">All messages submitted through the website contact form.</p>
  </div>
</section>

<section style="padding:48px 0 96px;">
  <div class="container">

    <!-- Stats row -->
    <div class="row g-3 mb-5">
      <div class="col-md-3">
        <div class="strength-card text-center fade-up" style="padding:24px;">
          <div style="font-family:var(--font-h);font-size:2rem;font-weight:800;color:var(--primary);">@Model.Count</div>
          <div style="font-size:.82rem;color:var(--text-muted);font-weight:600;">Total Enquiries</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="strength-card text-center fade-up" style="padding:24px;">
          <div style="font-family:var(--font-h);font-size:2rem;font-weight:800;color:var(--accent);">@Model.Count(m => !m.IsRead)</div>
          <div style="font-size:.82rem;color:var(--text-muted);font-weight:600;">Unread</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="strength-card text-center fade-up" style="padding:24px;">
          <div style="font-family:var(--font-h);font-size:2rem;font-weight:800;color:#28a745;">@Model.Count(m => m.IsRead)</div>
          <div style="font-size:.82rem;color:var(--text-muted);font-weight:600;">Read</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="strength-card text-center fade-up" style="padding:24px;">
          <div style="font-family:var(--font-h);font-size:2rem;font-weight:800;color:var(--primary);">@(Model.Any() ? Model.Max(m => m.SubmittedAt).ToString("dd MMM") : "—")</div>
          <div style="font-size:.82rem;color:var(--text-muted);font-weight:600;">Latest Enquiry</div>
        </div>
      </div>
    </div>

    @if (!Model.Any())
    {
      <div class="text-center py-5">
        <i class="bi bi-inbox" style="font-size:3rem;color:var(--grey);"></i>
        <h4 class="mt-3" style="color:var(--primary);">No enquiries yet</h4>
        <p style="color:var(--text-muted);">Contact form submissions will appear here.</p>
      </div>
    }
    else
    {
      <div class="row g-4">
        @foreach (var msg in Model)
        {
        <div class="col-12 fade-up">
          <div style="background:var(--white);border:1px solid @(msg.IsRead ? "var(--grey-mid)" : "var(--accent)");border-left:4px solid @(msg.IsRead ? "var(--grey-mid)" : "var(--accent)");border-radius:var(--radius-lg);padding:28px 32px;transition:var(--transition);">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
              <div>
                <div class="d-flex align-items-center gap-2 mb-1">
                  <span style="font-family:var(--font-h);font-size:1rem;font-weight:700;color:var(--primary);">@msg.FullName</span>
                  @if (!msg.IsRead)
                  {
                    <span style="background:var(--accent);color:#fff;font-family:var(--font-h);font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 10px;border-radius:100px;">New</span>
                  }
                </div>
                <div style="font-size:.85rem;color:var(--text-muted);">
                  <i class="bi bi-envelope me-1"></i>@msg.Email
                  @if (!string.IsNullOrEmpty(msg.Phone)) { <span class="ms-3"><i class="bi bi-telephone me-1"></i>@msg.Phone</span> }
                  @if (!string.IsNullOrEmpty(msg.Company)) { <span class="ms-3"><i class="bi bi-building me-1"></i>@msg.Company</span> }
                </div>
              </div>
              <div class="d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(msg.ProjectType))
                {
                  <span class="project-badge">@msg.ProjectType</span>
                }
                <span style="font-size:.8rem;color:var(--text-muted);">@msg.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                @if (!msg.IsRead)
                {
                <form asp-action="MarkRead" asp-route-id="@msg.Id" method="post" style="margin:0;">
                  @Html.AntiForgeryToken()
                  <button type="submit" style="background:var(--grey-light);border:1px solid var(--grey-mid);border-radius:var(--radius);padding:5px 14px;font-family:var(--font-h);font-size:.7rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-muted);cursor:pointer;transition:var(--transition);" title="Mark as read">
                    <i class="bi bi-check2"></i> Mark Read
                  </button>
                </form>
                }
              </div>
            </div>
            <div style="font-family:var(--font-h);font-size:.8rem;font-weight:700;color:var(--primary);margin-bottom:8px;">@msg.Subject</div>
            <p style="font-size:.9rem;color:var(--text-body);line-height:1.75;margin:0;white-space:pre-line;">@msg.Message</p>
          </div>
        </div>
        }
      </div>
    }
  </div>
</section>
