@{
    ViewData["Title"] = "Design Management";
}

<section class="page-hero">
  <div class="container position-relative" style="z-index:2;">
    <ul class="bc-nav">
      <li><a href="/">Home</a></li>
      <li class="bc-sep">/</li>
      <li><a href="/Services">Services</a></li>
      <li class="bc-sep">/</li>
      <li class="active">Design Management</li>
    </ul>
    <h1 class="page-hero-title">Design Management</h1>
    <p class="page-hero-sub">We lead and advise the design process to ensure every discipline remains aligned with the client's objectives — technically sound, commercially viable, and strategically planned from the start.</p>
  </div>
</section>

<section class="section-pad">
  <div class="container">
    <div class="row g-5 align-items-start">
      <div class="col-lg-8">
        <div class="mb-5 fade-up">
          <span class="section-label">Service Overview</span>
          <h2 class="section-title" style="font-size:1.8rem;">Design Management</h2>
          <div class="divider-accent"></div>
          <p style="color:var(--text-muted);line-height:1.85;font-size:1rem;">We lead and advise the design process to ensure every discipline remains aligned with the client's objectives — technically sound, commercially viable, and strategically planned from the start.</p>
        </div>
        <div class="mb-3">
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-check2"></i></div>
          <div>
            <div class="feature-text-title">Design Coordination & Advisory</div>
            <div class="feature-text-desc">We lead and advise the design process to ensure every discipline — architectural, structural, MEP, specialist consultants — remains aligned with the client's objectives. Our involvement ensures designs are visually compelling and technically sound.</div>
          </div>
        </div>
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-check2"></i></div>
          <div>
            <div class="feature-text-title">Client-Side Design Leadership</div>
            <div class="feature-text-desc">Acting as the client's representative, we ensure design development reflects your priorities, functional requirements, commercial expectations, and long-term asset goals — with clarity and structure throughout.</div>
          </div>
        </div>
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-check2"></i></div>
          <div>
            <div class="feature-text-title">Technical Review & Risk Identification</div>
            <div class="feature-text-desc">We conduct independent reviews of drawings, specifications, and design proposals to identify gaps, coordination issues, constructability challenges, and cost impacts early — before they become variations.</div>
          </div>
        </div>
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-check2"></i></div>
          <div>
            <div class="feature-text-title">Design Program Management</div>
            <div class="feature-text-desc">Our team oversees design timelines, milestones, deliverables, and interdependencies across disciplines — ensuring the design program supports procurement, approvals, and construction requirements.</div>
          </div>
        </div>
        <div class="service-feature-item fade-up">
          <div class="feature-check"><i class="bi bi-check2"></i></div>
          <div>
            <div class="feature-text-title">Value-Driven Design & Cost Alignment</div>
            <div class="feature-text-desc">We work closely with designers and QS teams to ensure design choices reflect realistic budgets, efficient material usage, and value-engineered solutions that enhance performance while controlling cost.</div>
          </div>
        </div>
        </div>
      </div>
      <div class="col-lg-4 fade-in">
        <div class="contact-card" style="position:sticky;top:100px;border-top:4px solid var(--accent);">
          <div class="service-icon-wrap mb-3"><i class="bi bi-pencil-square" style="font-size:1.7rem;color:var(--accent);"></i></div>
          <h4 style="font-family:var(--font-h);font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:12px;">Design Management</h4>
          <div style="background:rgba(35,137,202,.08);border-radius:var(--radius);padding:16px;margin-bottom:20px;">
            <div style="font-family:var(--font-h);font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:8px;">Best For</div>
            <p style="font-size:.88rem;color:var(--text-muted);line-height:1.65;margin:0;">Clients who want structured design coordination, clear advisory support, commercial alignment, and early risk control.</p>
          </div>
          <a href="/Contact" class="btn-pb w-100" style="justify-content:center;"><i class="bi bi-envelope-fill"></i> Enquire Now</a>
          <a href="/Services" class="btn-od w-100 mt-2" style="justify-content:center;"><i class="bi bi-arrow-left"></i> All Services</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-section section-pad">
  <div class="container position-relative fade-up">
    <div class="row">
      <div class="col-lg-7">
        <h2 class="cta-title">Interested in Design Management?</h2>
        <p class="cta-subtitle">Contact us for a confidential, obligation-free consultation to discuss how this service can benefit your project.</p>
        <a href="/Contact" class="btn-pb" style="background:rgba(255,255,255,.15);backdrop-filter:blur(10px);border:1.5px solid rgba(255,255,255,.4);box-shadow:none;">
          <i class="bi bi-envelope-fill"></i> Contact Us Today
        </a>
      </div>
    </div>
  </div>
</section>
