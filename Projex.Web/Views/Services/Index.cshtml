<!-- ════ HOW WE WORK ════ -->
<section class="section-pad" style="background:var(--off-white,#F7F6F3);">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">Our Approach</span>
      <h2 class="section-title">How We Work</h2>
      <div class="divider-accent center"></div>
      <p class="section-subtitle mx-auto">Strategic. Transparent. Disciplined. Our approach blends advisory intelligence with structured delivery methods.</p>
    </div>
    <div class="row g-4 stagger-parent">
      @{
        var steps = new[] {
          ("01","Understand the Vision","We begin by understanding the objectives, constraints, risks, and expectations."),
          ("02","Inform &amp; Advise","We provide strategic recommendations backed by technical and commercial insight."),
          ("03","Plan &amp; Structure","We define governance frameworks, communication pathways, schedules, and cost parameters."),
          ("04","Coordinate &amp; Execute","We align consultants, manage contractors, and maintain progress with discipline."),
          ("05","Monitor &amp; Control","Through continuous oversight, we ensure the project stays on track — commercially and operationally."),
          ("06","Deliver &amp; Protect Value","Every decision and action is made to protect your interests and maximise long-term value.")
        };
        foreach (var (num, title, desc) in steps)
        {
      <div class="col-lg-4 col-md-6 fade-up">
        <div class="strength-card h-100">
          <div style="font-family:var(--font-h);font-size:2.4rem;font-weight:800;color:var(--border,#E8E8E4);line-height:1;margin-bottom:16px;">@num</div>
          <div class="strength-title">@Html.Raw(title)</div>
          <div class="strength-text">@desc</div>
        </div>
      </div>
        }
      }
    </div>
  </div>
</section>

<!-- ════ CTA ════ -->
<section class="cta-section section-pad">
  <div class="container">
    <div class="cta-section-inner fade-up">
      <span class="section-label" style="color:rgba(255,255,255,.4);">Start a Conversation</span>
      <h2 class="cta-title">Ready to Discuss Your Project?</h2>
      <p class="cta-subtitle">Let us provide the clarity and commercially intelligent advisory your project deserves.</p>
      <div class="d-flex gap-3 flex-wrap justify-content-center">
        <a href="/Contact" class="btn-pb"><i class="bi bi-envelope-fill"></i> Contact Us Today</a>
        <a href="/About" class="btn-ob"><i class="bi bi-info-circle"></i> About Us</a>
      </div>
    </div>
  </div>
</section>
