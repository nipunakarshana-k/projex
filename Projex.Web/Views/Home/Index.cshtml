<!-- ════════════════════════════════════════════════
     WHO WE ARE — Split image + text
════════════════════════════════════════════════ -->
<section class="section-pad" style="background:#fff;">
  <div class="container">
    <div class="row align-items-center g-5">

      <!-- Image -->
      <div class="col-lg-5 fade-up">
        <div class="split-image-block">
