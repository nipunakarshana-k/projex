          <div class="col-sm-6">
            <div class="value-card fade-up h-100">
              <div class="value-label">Principle 01</div>
              <div class="value-title">Excellence</div>
              <div class="value-desc">In advisory quality, technical insight, and client service at every stage.</div>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="value-card fade-up h-100">
              <div class="value-label">Principle 02</div>
              <div class="value-title">Execution</div>
              <div class="value-desc">Structured, consistent, and proactive management across every project phase.</div>
            </div>
          </div>
        </div>
        <a href="/About" class="btn-od">
          <i class="bi bi-arrow-right-circle"></i> Our Story
        </a>
      </div>

    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════
     STATS BAR — 4 bold numbers
════════════════════════════════════════════════ -->
<div class="stats-bar fade-in">
  <div class="container">
    <div class="stats-bar-grid">
      <div class="stats-bar-item">
        <div class="stats-bar-num"><span class="count-up" data-target="17" data-suffix="+">17+</span></div>
        <div class="stats-bar-lbl">Years of Experience</div>
      </div>
      <div class="stats-bar-item">
        <div class="stats-bar-num">3</div>
        <div class="stats-bar-lbl">Countries Active</div>
      </div>
      <div class="stats-bar-item">
