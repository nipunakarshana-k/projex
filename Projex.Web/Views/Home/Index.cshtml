@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<!-- ════════════════════════════════════════════════
     HERO — Full-bleed image, minimal overlay text
════════════════════════════════════════════════ -->
<section class="hero-section"
         style="background-image:url('/images/colombo-aerial.jpg');
                background-size:cover;background-position:center;">
  <div class="hero-bg-pattern"></div>
  <div class="hero-watermark">PROJEX</div>

  <div class="hero-container">
    <div class="hero-inner">

      <!-- LEFT: Text -->
      <div class="hero-left hero-content">
        <span class="section-label" style="color:rgba(255,255,255,.5);margin-bottom:20px;">
          Sri Lanka · Singapore · Australia
        </span>
        <h1 class="hero-title">
          Independent Advisory.<br>
          <span class="accent-text">Intelligent Cost Insight.</span><br>
          Structured Delivery.
        </h1>
        <p class="hero-subtitle">
          We protect your commercial interests and guide your project from concept to completion — with clarity, discipline, and trusted client-side leadership.
        </p>
        <div class="hero-pillars">
          <span class="hero-pillar">Excellence</span>
          <span class="hero-pillar">Execution</span>
          <span class="hero-pillar">Expertise</span>
        </div>
        <div class="hero-actions">
          <a href="/Services" class="btn-pb">
            <i class="bi bi-grid-3x3-gap-fill"></i> Our Services
          </a>
        </div>
      </div>

      <!-- RIGHT: Stats -->
      <div class="hero-right">
        <div class="stat-card fade-up">
          <div class="stat-num"><span class="count-up" data-target="17" data-suffix="">17</span><span class="stat-plus">+</span></div>
          <div class="stat-lbl">Years International Experience</div>
          <div class="stat-sub">Across three continents</div>
        </div>
        <div class="stat-card stat-card-accent fade-up">
          <div class="stat-num">3</div>
          <div class="stat-lbl">Countries of Operation</div>
          <div class="stat-sub">Sri Lanka · Singapore · Australia</div>
        </div>
        <div class="stat-card fade-up">
          <div class="stat-num">100<span class="stat-plus">%</span></div>
          <div class="stat-lbl">Client-Side Independent</div>
          <div class="stat-sub">Always acting in your interest</div>
        </div>
      </div>

    </div>
  </div>

</section>

<!-- ════════════════════════════════════════════════
     TRUST MARQUEE STRIP
════════════════════════════════════════════════ -->
<div class="trust-strip">
  <div class="marquee-track">
    <span class="marquee-item"><i class="bi bi-shield-check"></i> Client-Side Advisory</span>
    <span class="marquee-item"><i class="bi bi-diagram-3"></i> Project Management</span>
    <span class="marquee-item"><i class="bi bi-pencil-square"></i> Design Management</span>
    <span class="marquee-item"><i class="bi bi-calculator"></i> Cost Consultancy</span>
    <span class="marquee-item"><i class="bi bi-globe2"></i> International Experience</span>
    <span class="marquee-item"><i class="bi bi-bar-chart-line"></i> Commercial Intelligence</span>
    <span class="marquee-item"><i class="bi bi-buildings"></i> Built Environment</span>
    <span class="marquee-item"><i class="bi bi-shield-check"></i> Client-Side Advisory</span>
    <span class="marquee-item"><i class="bi bi-diagram-3"></i> Project Management</span>
    <span class="marquee-item"><i class="bi bi-pencil-square"></i> Design Management</span>
    <span class="marquee-item"><i class="bi bi-calculator"></i> Cost Consultancy</span>
    <span class="marquee-item"><i class="bi bi-globe2"></i> International Experience</span>
    <span class="marquee-item"><i class="bi bi-bar-chart-line"></i> Commercial Intelligence</span>
    <span class="marquee-item"><i class="bi bi-buildings"></i> Built Environment</span>
