@model List<Project>
@{
    ViewData["Title"] = "Projects";
}

<!-- ════ PAGE HERO ════ -->
<section class="page-hero-mm"
         style="background-image:url('/images/6.jpg');">
  <div class="page-hero-mm-overlay"></div>
  <div class="container page-hero-mm-inner">
    <ul class="bc-nav">
      <li><a href="/">Home</a></li>
      <li class="bc-sep">/</li>
      <li class="active">Projects</li>
    </ul>
    <h1 class="page-hero-mm-title">Our Projects</h1>
    <p class="page-hero-mm-sub">A selection of projects where we have delivered strategic clarity, commercial protection, and structured execution for our clients.</p>
  </div>
</section>

<!-- ════ PROJECTS GRID ════ -->
<section class="section-pad" style="background:#fff;">
  <div class="container">

    @if (!Model.Any())
    {
    <!-- Empty state -->
    <div style="text-align:center;padding:80px 0;">
      <div style="width:80px;height:80px;border-radius:50%;background:var(--off-white,#F7F6F3);border:1px solid var(--border,#E8E8E4);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
        <i class="bi bi-building" style="font-size:2rem;color:var(--grey);"></i>
      </div>
      <h3 style="font-family:var(--font-h);font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:12px;">Portfolio Coming Soon</h3>
      <p style="color:var(--text-muted);max-width:420px;margin:0 auto 32px;line-height:1.75;">
        We are currently curating our project portfolio. In the meantime, get in touch to discuss how we can support your project.
      </p>
      <a href="/Contact" class="btn-pb"><i class="bi bi-envelope-fill"></i> Discuss Your Project</a>
    </div>
    }
    else
    {
    <div class="row g-4 stagger-parent justify-content-center">
      @foreach (var project in Model)
      {
      <div class="col-lg-6 col-md-6 fade-up">
        <div class="project-card">
          <div class="project-img">
            @if (!string.IsNullOrEmpty(project.ImageUrl))
            {
              <img src="@project.ImageUrl" alt="@project.Name" loading="lazy" />
            }
            else
            {
              <img src="/images/11.jpg"
                   alt="@project.Name" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
            }
          </div>
          <div class="project-body">
            <div class="mb-2">
              @if (!string.IsNullOrEmpty(project.Category))
              { <span class="project-badge">@project.Category</span> }
              @if (project.Status == "Ongoing")
              { <span class="status-ongoing">Ongoing</span> }
              else if (!string.IsNullOrEmpty(project.Status))
              { <span class="status-completed">@project.Status</span> }
            </div>
            <div class="project-name">@project.Name</div>
            <div class="project-meta">
              @if (!string.IsNullOrEmpty(project.Location)) { <span><i class="bi bi-geo-alt"></i> @project.Location</span> }
              @if (!string.IsNullOrEmpty(project.Client)) { <span><i class="bi bi-building"></i> @project.Client</span> }
              @if (!string.IsNullOrEmpty(project.Role)) { <span><i class="bi bi-briefcase"></i> @project.Role</span> }
            </div>
            @if (!string.IsNullOrEmpty(project.Overview))
            {
              <p class="project-desc">@(project.Overview.Length > 160 ? project.Overview.Substring(0, 160) + "…" : project.Overview)</p>
            }
            <a href="/Projects/Detail/@project.Id" class="service-link mt-3 d-inline-flex">
              View Details <i class="bi bi-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
      }
    </div>
    }

  </div>
</section>

<!-- ════ DELIVERABLES ════ -->
<section class="section-pad" style="background:var(--off-white,#F7F6F3);">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">DELIVERS</span>
      <h2 class="section-title">Our Commitment on Every Project</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4 stagger-parent">
      <div class="col-lg-4 col-md-6 fade-up">
        <div class="strength-card h-100 text-center">
          <div class="strength-icon mx-auto mb-3"><i class="bi bi-check2-circle" style="color:var(--accent);"></i></div>
          <div class="strength-title">Strategic Clarity From Day One</div>
          <div class="strength-text">We ensure the project starts with defined objectives, structured planning, and clear decision pathways.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6 fade-up">
        <div class="strength-card h-100 text-center">
          <div class="strength-icon mx-auto mb-3"><i class="bi bi-search" style="color:var(--accent);"></i></div>
          <div class="strength-title">Early Identification of Risks and Opportunities</div>
          <div class="strength-text">Reducing uncertainty, avoiding surprises, and improving alignment across the team.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6 fade-up">
        <div class="strength-card h-100 text-center">
          <div class="strength-icon mx-auto mb-3"><i class="bi bi-shield-check" style="color:var(--accent);"></i></div>
          <div class="strength-title">Strong Governance and Controlled Execution</div>
          <div class="strength-text">Ensuring disciplined progress, transparent reporting, and predictable outcomes.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6 fade-up">
        <div class="strength-card h-100 text-center">
          <div class="strength-icon mx-auto mb-3"><i class="bi bi-cash-stack" style="color:var(--accent);"></i></div>
          <div class="strength-title">Commercial Protection Through Cost Intelligence</div>
          <div class="strength-text">Safeguarding investment value through continuous cost monitoring and evaluation.</div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6 fade-up">
        <div class="strength-card h-100 text-center">
          <div class="strength-icon mx-auto mb-3"><i class="bi bi-diagram-3" style="color:var(--accent);"></i></div>
          <div class="strength-title">Seamless Coordination Across Consultants and Contractors</div>
          <div class="strength-text">Promoting cooperation, accountability, and timely resolution of issues.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ CTA ════ -->
<section class="cta-section section-pad">
  <div class="container">
    <div class="cta-section-inner fade-up">
      <span class="section-label" style="color:rgba(255,255,255,.4);">Have a Project in Mind?</span>
      <h2 class="cta-title">Have a Project in Mind?</h2>
      <p class="cta-subtitle">Let us guide you with clarity, structure, and commercially intelligent advice tailored to your project's specific needs.</p>
      <div class="d-flex gap-3 flex-wrap justify-content-center">
        <a href="/Contact" class="btn-pb"><i class="bi bi-envelope-fill"></i> Contact Us</a>
        <a href="/Services" class="btn-ob"><i class="bi bi-grid-3x3-gap-fill"></i> Our Services</a>
      </div>
    </div>
  </div>
</section>
