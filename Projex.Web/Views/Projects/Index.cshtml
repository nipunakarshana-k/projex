@model List<Project>
@{
    ViewData["Title"] = "Projects";
}

<section class="page-hero">
  <div class="container position-relative" style="z-index:2;">
    <ul class="bc-nav">
      <li><a href="/">Home</a></li>
      <li class="bc-sep">/</li>
      <li class="active">Projects</li>
    </ul>
    <h1 class="page-hero-title">Our Projects</h1>
    <p class="page-hero-sub">A selection of projects where we have delivered strategic clarity, commercial protection, and structured execution for our clients.</p>
  </div>
</section>

<section class="section-pad">
  <div class="container">
    @if (!Model.Any())
    {
    <div class="text-center py-5">
      <i class="bi bi-building" style="font-size:4rem;color:var(--grey);"></i>
      <h3 class="mt-4" style="color:var(--primary);">Projects Coming Soon</h3>
      <p style="color:var(--text-muted);">We are currently updating our project portfolio. Please check back soon.</p>
      <a href="/Contact" class="btn-pb mt-3">Discuss Your Project</a>
    </div>
    }
    else
    {
    <div class="row g-4 stagger-parent">
      @foreach (var project in Model)
      {
      <div class="col-lg-6 col-md-6">
        <div class="project-card fade-up">
          <div class="project-img">
            @if (!string.IsNullOrEmpty(project.ImageUrl))
            {
              <img src="@project.ImageUrl" alt="@project.Name" />
            }
            else
            {
              <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;">
                <i class="bi bi-building project-ph"></i>
                <span style="font-family:var(--font-h);font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);">@project.Category</span>
              </div>
            }
          </div>
          <div class="project-body">
            <div>
              @if (!string.IsNullOrEmpty(project.Category))
              {
                <span class="project-badge">@project.Category</span>
              }
              @if (project.Status == "Ongoing")
              {
                <span class="status-ongoing">Ongoing</span>
              }
              else if (!string.IsNullOrEmpty(project.Status))
              {
                <span class="status-completed">@project.Status</span>
              }
            </div>
            <div class="project-name mt-2">@project.Name</div>
            <div class="project-meta">
              @if (!string.IsNullOrEmpty(project.Location))
              {
                <div><i class="bi bi-geo-alt me-1"></i>@project.Location</div>
              }
              @if (!string.IsNullOrEmpty(project.Client))
              {
                <div><i class="bi bi-building me-1"></i>@project.Client</div>
              }
              @if (!string.IsNullOrEmpty(project.Role))
              {
                <div><i class="bi bi-briefcase me-1"></i>@project.Role</div>
              }
            </div>
            @if (!string.IsNullOrEmpty(project.Overview))
            {
              <p class="project-desc">@(project.Overview.Length > 160 ? project.Overview.Substring(0, 160) + "..." : project.Overview)</p>
            }
            <a href="/Projects/Detail/@project.Id" class="service-link mt-3 d-inline-flex">
              View Details <i class="bi bi-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
      }
    </div>
    }
  </div>
</section>

<!-- Deliverables -->
<section class="section-pad bg-grey-light">
  <div class="container">
    <div class="text-center mb-5 fade-up">
      <span class="section-label">What We Deliver</span>
      <h2 class="section-title">Our Commitment on Every Project</h2>
      <div class="divider-accent center"></div>
    </div>
    <div class="row g-4 stagger-parent">
      <div class="col-lg-3 col-md-6"><div class="strength-card fade-up h-100 text-center"><div class="strength-icon mx-auto mb-3"><i class="bi bi-bullseye" style="color:var(--accent);"></i></div><div class="strength-title">Strategic Clarity</div><div class="strength-text">Defined objectives, structured planning, and clear decision pathways from day one.</div></div></div>
      <div class="col-lg-3 col-md-6"><div class="strength-card fade-up h-100 text-center"><div class="strength-icon mx-auto mb-3"><i class="bi bi-search" style="color:var(--accent);"></i></div><div class="strength-title">Early Risk Identification</div><div class="strength-text">Reducing uncertainty, avoiding surprises, and improving alignment across the team.</div></div></div>
      <div class="col-lg-3 col-md-6"><div class="strength-card fade-up h-100 text-center"><div class="strength-icon mx-auto mb-3"><i class="bi bi-shield-fill-check" style="color:var(--accent);"></i></div><div class="strength-title">Strong Governance</div><div class="strength-text">Disciplined progress, transparent reporting, and predictable outcomes at every stage.</div></div></div>
      <div class="col-lg-3 col-md-6"><div class="strength-card fade-up h-100 text-center"><div class="strength-icon mx-auto mb-3"><i class="bi bi-cash-coin" style="color:var(--accent);"></i></div><div class="strength-title">Commercial Protection</div><div class="strength-text">Safeguarding investment value through continuous cost monitoring and evaluation.</div></div></div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section section-pad">
  <div class="container position-relative fade-up">
    <div class="row">
      <div class="col-lg-7">
        <h2 class="cta-title">Have a Project in Mind?</h2>
        <p class="cta-subtitle">Let us guide you with clarity, structure, and commercially intelligent advice tailored to your project's specific needs.</p>
        <a href="/Contact" class="btn-pb" style="background:rgba(255,255,255,.15);backdrop-filter:blur(10px);border:1.5px solid rgba(255,255,255,.4);box-shadow:none;">
          <i class="bi bi-envelope-fill"></i> Contact Us
        </a>
      </div>
    </div>
  </div>
</section>
